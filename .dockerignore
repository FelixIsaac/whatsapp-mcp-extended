whatsapp-mcp-server/**/*.pyc
whatsapp-mcp-server/.pytest_cache/
whatsapp-mcp-server/tests/

# Node / Next.js
whatsapp-web-ui/node_modules/
whatsapp-web-ui/.next/
whatsapp-web-ui/out/

# Go build artifacts
whatsapp-bridge/whatsapp-bridge

# Docs / misc
*.md
docs/
